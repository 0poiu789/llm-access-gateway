# ══════════════════════════════════════════════════════════
# LLM Access Gateway — 사용자 매핑 및 OpenAI Key 설정
# ══════════════════════════════════════════════════════════
#
# 사용법:
#   1) cp config/users.conf.example config/users.conf
#   2) 아래 ADMIN과 USERS 항목을 사내 실값으로 편집
#   3) ./start.sh  실행 (기존 설치에서도 동일, 변경분만 적용됨)
#
# 보안: config/users.conf 는 OpenAI Key를 평문으로 포함한다.
#   - .gitignore에 의해 git 커밋 자동 차단
#   - chmod 600으로 권한 제한 (start.sh가 자동 적용)
#
# ══════════════════════════════════════════════════════════

# ── 관리자 (Master Key 외에 패스워드로도 UI 로그인 가능) ──
ADMIN_EMAIL="admin@local"
ADMIN_PASSWORD="admin-pw-change-me"

# ── 일반 사용자 (최대 10명, user01~user10 슬롯) ──
#
# 형식: "SLOT|EMAIL|NAME|PASSWORD|OPENAI_API_KEY"
#   - SLOT: user01 ~ user10 중 하나 (litellm/config.yaml의 model_name과 매칭)
#   - EMAIL: UI 로그인 ID, /user/new의 user_email
#   - NAME: 표시용 (관리자 UI에 보임)
#   - PASSWORD: 사용자 UI 로그인용 초기 비밀번호 (사용자가 변경 가능)
#   - OPENAI_API_KEY: 해당 사용자가 사용할 실제 OpenAI Key
#                      placeholder를 그대로 두면 OpenAI 호출 시 401 (다른 검증은 정상)
#
# 사용자가 적으면 그만큼만 적어도 됨 (1명만 설정 시 USERS 배열에 1줄만).
# 11명 이상이 필요하면 litellm/config.yaml과 docker-compose.yml도 함께 확장.

USERS=(
  "user01|alice@local|홍길동|alice-init-pw|sk-proj-poc-user01-placeholder-replace-with-real-key"
  "user02|bob@local|김철수|bob-init-pw|sk-proj-poc-user02-placeholder-replace-with-real-key"
  "user03|carol@local|이영희|carol-init-pw|sk-proj-poc-user03-placeholder-replace-with-real-key"
  "user04|dave@local|박민수|dave-init-pw|sk-proj-poc-user04-placeholder-replace-with-real-key"
  "user05|eve@local|최지은|eve-init-pw|sk-proj-poc-user05-placeholder-replace-with-real-key"
  "user06|frank@local|정서연|frank-init-pw|sk-proj-poc-user06-placeholder-replace-with-real-key"
  "user07|grace@local|강도현|grace-init-pw|sk-proj-poc-user07-placeholder-replace-with-real-key"
  "user08|henry@local|윤하은|henry-init-pw|sk-proj-poc-user08-placeholder-replace-with-real-key"
  "user09|ivy@local|장현우|ivy-init-pw|sk-proj-poc-user09-placeholder-replace-with-real-key"
  "user10|jack@local|한소율|jack-init-pw|sk-proj-poc-user10-placeholder-replace-with-real-key"
)
