.env
config/users.conf
openbao/data/
openbao/logs/
openbao/init-keys.json
postgres/
# 운영 cert이 들어가는 자리 (사내 CA 발급 파일 또는 dev 모드의 symlink)
nginx/certs/server.key
nginx/certs/server.crt
# 로컬 dev 산출물 전용 디렉토리 (운영과 분리)
