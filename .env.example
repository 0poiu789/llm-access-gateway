# ══════════════════════════════════════════════
# LLM Access Gateway 환경변수
# start.sh가 최초 실행 시 이 파일을 .env로 복사하고
# 랜덤한 Master Key / PG 비밀번호로 채운다.
#
# OpenAI Key는 이 파일에 두지 않는다 — OpenBao + secrets/litellm-secrets.env
# (자동 렌더링)에서 관리. set-openai-key.sh로 적재.
# ══════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_PASSWORD=CHANGE_ME

# ── LiteLLM ──
LITELLM_MASTER_KEY=sk-master-CHANGE_ME
# PROXY_BASE_URL: 브라우저/Codex CLI가 게이트웨이에 도달할 때 사용하는 URL.
# start.sh가 .env를 처음 만들 때 호스트의 IP를 자동 감지하여 설정한다.
# 도메인이 있다면 https://llm-gateway.사내도메인 형태로 직접 수정하여도 무방.
PROXY_BASE_URL=https://localhost

# ── OIDC SSO (선택, 비워두면 SSO 비활성) ──
GENERIC_CLIENT_ID=
GENERIC_CLIENT_SECRET=
GENERIC_AUTHORIZATION_ENDPOINT=
GENERIC_TOKEN_ENDPOINT=
GENERIC_USERINFO_ENDPOINT=

GENERIC_USER_ID_JWT_FIELD=sub
GENERIC_USER_EMAIL_JWT_FIELD=email
GENERIC_USER_FIRST_NAME_JWT_FIELD=given_name
GENERIC_USER_LAST_NAME_JWT_FIELD=family_name
GENERIC_USER_ROLE_JWT_FIELD=groups

ALLOWED_USER_EMAIL_DOMAINS=
DEFAULT_USER_ROLES_LITELLM_SSO=internal_user_viewer
